includes:
    - vendor/symplify/phpstan-rules/config/phpunit-rules.neon
    - vendor/symplify/phpstan-rules/config/static-rules.neon
    - vendor/phpstan/phpstan/conf/bleedingEdge.neon

rules:
    - Shopware\PayPalSDK\Test\PHPStan\StructRule
    - Shopware\PayPalSDK\Test\PHPStan\StructMethodRule
    - Shopware\PayPalSDK\Test\PHPStan\GatewayRule

parameters:
    level: max
    tmpDir: var/cache/phpstan
    treatPhpDocTypesAsCertain: false
    checkFunctionNameCase: true
    checkInternalClassCaseSensitivity: true
    reportUnmatchedIgnoredErrors: true
    reportMaybesInMethodSignatures: false
    reportStaticMethodSignatures: false
    reportMaybesInPropertyPhpDocTypes: false

    strictRules:
        allRules: false
        disallowedLooseComparison: true
        strictFunctionCalls: true
        overwriteVariablesWithLoop: true
        matchingInheritedMethodNames: true
        disallowedEmpty: true

    paths:
        - src
        - tests

    ignoreErrors:
        - identifier: symplify.forbiddenExtendOfNonAbstractClass

        - # Tests are allowed to do so
          identifier: symplify.multipleClassLikeInFile
          path: tests/*

        - # Token should be private
          identifier: struct.property.protected
          path: src/Struct/V1/Token.php

        - # That's what they meant for
          message: '#.*#'
          paths:
              - tests/fixture/Struct/PHPStanRuleStruct.php
              - tests/fixture/Gateway/PHPStanRuleGateway.php
